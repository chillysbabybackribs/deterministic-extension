{
  "manifest_version": 3,
  "name": "Browser Chat Assistant",
  "version": "0.0.1",
  "description": "A chat-first browser assistant with direct Claude Haiku 4.5 browser tools.",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Browser Chat Assistant"
  },
  "background": {
    "service_worker": "background/serviceWorker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/app/index.html"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "scripting",
    "storage",
    "sidePanel",
    "history",
    "search"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "http://*/*",
    "https://*/*"
  ]
}
